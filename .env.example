# ============================================================
# RTMPayServer — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# PostgreSQL password (choose a strong random password)
POSTGRES_PASSWORD=changeme_strong_password

# BTCPayServer public hostname (no protocol, no trailing slash)
# Example: rtmpay.yourdomain.com
BTCPAY_HOST=rtmpay.yourdomain.com

# Port to expose BTCPayServer on the host
BTCPAY_PORT=23001

# Network: mainnet or testnet
BTCPAY_NETWORK=mainnet

# Raptoreum node RPC credentials
# If using external node, also set RTM_NODE_HOST to its IP/hostname
RTM_RPC_USER=rtmrpcuser
RTM_RPC_PASSWORD=changeme_rtm_rpc_password
RTM_RPC_PORT=10225
RTM_P2P_PORT=10226

# External RTM node host (leave empty to use built-in rtmpay-raptoreumd)
# RTM_NODE_HOST=10.0.0.5
